      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1255660484718592]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1255660485193729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1255660485369858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1255660485791747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1255660486029316]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 3 THEN &quot;Fast (0-3 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 7 THEN &quot;Standard (4-7 Days)&quot;&#13;&#10;ELSE &quot;Delayed (8+ Days)&quot;&#13;&#10;END' />
      </column>
      <column caption='Number of records' datatype='integer' name='[Calculation_1255660497924103]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([order_id])' />
      </column>
      <column caption='Return Rate (copy)' datatype='real' name='[Return Rate (copy)_1255660506238985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
